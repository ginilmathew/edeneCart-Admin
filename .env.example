# API origin only (no /v1/api — paths already include it). Unset in dev to use Vite proxy.
# Production builds default to Railway unless you override:
# VITE_API_BASE_URL=https://edencartapi-production.up.railway.app
# Local direct-to-Nest (optional):
# VITE_API_BASE_URL=http://localhost:3000
#
# When VITE_API_BASE_URL is unset in dev, India Post uses Vite → test.cept.gov.in (no Nest).
# Optional defaults for that path (otherwise use the India Post form on the page):
# VITE_INDIA_POST_USERNAME=
# VITE_INDIA_POST_PASSWORD=
